# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=TranscriptAI
DEBUG=false
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/transcriptai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/tmp/transcriptai/storage

# For S3 (set STORAGE_BACKEND=s3):
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI Models ─────────────────────────────────────────────────────────────────
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto          # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=float16 # float32 | float16 | int8
WHISPER_BATCH_SIZE=16
USE_WHISPERX=true
ENABLE_DIARIZATION=true

# HuggingFace token — required for speaker diarization (pyannote)
# Accept pyannote terms at: https://huggingface.co/pyannote/speaker-diarization
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=5000
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_SECONDS=7200

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,https://app.yourdomain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
